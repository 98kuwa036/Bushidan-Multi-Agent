# ============================================================================
# Bushidan Multi-Agent System v9.4 - Configuration Template
# Copy this file to .env and fill in your API keys
# ============================================================================

# System Configuration
SYSTEM_MODE=battalion  # battalion, company, platoon

# ============================================================================
# Required API Keys
# ============================================================================
CLAUDE_API_KEY=your_claude_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# Optional API Keys
# ============================================================================
GROQ_API_KEY=your_groq_api_key_here          # For Simple tasks (Groq Llama 3.3 70B)
ALIBABA_API_KEY=your_alibaba_api_key_here    # For Kagemusha (Cloud Qwen3-plus)
TAVILY_API_KEY=your_tavily_api_key_here      # For web search
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token    # For Slack integration
NOTION_TOKEN=secret_your-notion-token        # For long-term memory

# ============================================================================
# llama.cpp Configuration (v9.4 - HP ProDesk 600 CPU Optimized)
# ============================================================================
LLAMACPP_ENDPOINT=http://127.0.0.1:8080
LLAMACPP_MODEL_PATH=models/qwen3/Qwen3-Coder-30B-Q4_K_M.gguf
LLAMACPP_THREADS=8          # HP ProDesk 600: i5/i7 6-8 cores
LLAMACPP_CONTEXT_SIZE=4096  # Reduced for CPU speed
LLAMACPP_BATCH_SIZE=512     # CPU optimal
LLAMACPP_MLOCK=true         # Lock memory to prevent swapping
USE_LLAMACPP=true           # true=llama.cpp, false=Ollama(legacy)

# Legacy: Ollama (v9.3以前、現在未使用)
# OLLAMA_ENDPOINT=http://localhost:11434

# LiteLLM Proxy (optional)
LITELLM_ENDPOINT=http://localhost:8000

# ============================================================================
# Logging & Memory Configuration
# ============================================================================
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
MEMORY_FILE=bushidan_memory.jsonl
MEMORY_MAX_SIZE=10000       # Maximum entries before cleanup

# ============================================================================
# API Key Instructions
# ============================================================================
#
# 1. Claude API Key (Required):
#    - Get from: https://console.anthropic.com/
#    - Used for: Shogun (Strategic Layer) + Opus (Premium Review)
#    - Models: Claude Sonnet 4.5 + Opus 4
#    - Cost: Prompt Caching saves 90%
#
# 2. Gemini API Key (Required):
#    - Get from: https://ai.google.dev/
#    - Used for: Gemini 3.0 Flash (Final Defense)
#    - Cost: ~¥0.04/request (free tier available)
#
# 3. Groq API Key (Recommended):
#    - Get from: https://console.groq.com/
#    - Used for: Simple tasks (Llama 3.3 70B, 300-500 tok/s)
#    - Cost: FREE (unlimited for personal use)
#
# 4. Alibaba API Key (Optional):
#    - Get from: https://dashscope.console.aliyun.com/
#    - Used for: Kagemusha (Cloud Qwen3-plus, 32k context)
#    - Cost: ~¥3/request (context overflow handling)
#
# 5. Tavily API Key (Optional):
#    - Get from: https://tavily.com/
#    - Used for: Smart web search with content extraction
#    - Cost: Free tier 1,000 searches/month
#
# 6. Slack Bot Token (Optional):
#    - Get from: https://api.slack.com/apps
#    - Used for: Slack interface (@bushidan-bot)
#    - Cost: Free
#
# 7. Notion Token (Optional):
#    - Get from: https://www.notion.so/my-integrations
#    - Used for: Long-term memory (Layer 3)
#    - Cost: Free

# ============================================================================
# System Modes
# ============================================================================
#
# battalion - Full system (Shogun + Karo + Taisho + Ashigaru + All MCP)
#            Best for: Complex development tasks
#
# company   - Slack mode (Karo + Taisho + Ashigaru + Memory MCP)
#            Best for: Daily development work
#
# platoon   - HA OS mode (Taisho + Ashigaru + Dynamic MCP)
#            Best for: Voice queries, IoT integration

# ============================================================================
# Proxmox Container Configuration (Reference)
# ============================================================================
#
# CT 100 (本陣): 10GB - System orchestration, no model
# CT 101 (Qwen3): 45GB - llama.cpp + Qwen3-Coder-30B (~17GB model)
#
# See: scripts/setup_llamacpp_prodesck600.sh
# See: docs/LLAMACPP_SETUP.md
