# ============================================================================
# Bushidan Multi-Agent System v10.1 - Configuration Template
# このファイルを .env にコピーして各APIキーを記入してください
# ============================================================================

# システムモード
SYSTEM_MODE=battalion  # battalion, company, platoon

# ============================================================================
# 必須 APIキー
# ============================================================================

# 将軍 (Shogun) - Claude Sonnet / Opus
# https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# 最終防衛線 - Gemini 3.0 Flash
# https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# Qwen シリーズ - すべて OpenRouter 経由 (推奨)
# https://openrouter.ai/ でAPIキーを取得
# ============================================================================

# OpenRouter 共通キー (軍師・影武者の両方で使用)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 軍師 (Gunshi) - Qwen3-Coder-Next 80B via OpenRouter
QWEN3_CODER_NEXT_API_KEY=your_openrouter_api_key_here  # OpenRouterキーを流用
QWEN3_CODER_NEXT_PROVIDER=openrouter

# 影武者 (Kagemusha) - Qwen3-Coder-Plus via OpenRouter
ALIBABA_API_KEY=your_openrouter_api_key_here  # OpenRouterキーを流用 (Alibaba直接ではない)

# ============================================================================
# v10.1: Kimi K2.5 (傭兵 - 並列サブタスク実行)
# https://platform.moonshot.cn/ で取得 (または OpenRouter)
# ============================================================================
KIMI_API_KEY=your_moonshot_api_key_here
KIMI_PROVIDER=moonshot  # moonshot or openrouter

# ============================================================================
# その他のAPIキー
# ============================================================================

# Groq - Simple タスク高速処理 (無料)
# https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Tavily - Web検索MCP (1,000回/月無料)
# https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================================
# Smithery MCP
# アカウントごとに1つのAPIキー (各MCP共通)
# https://smithery.ai/ → Settings → API Keys
# ============================================================================
SMITHERY_API_KEY=your_smithery_api_key_here

# ※ 以下は Smithery とは別の各サービス独自のAPIキー (任意)
# EXA_API_KEY=your_exa_api_key_here       # https://exa.ai/ (セマンティック検索)
# MEM0_API_KEY=your_mem0_api_key_here     # https://mem0.ai/ (グラフ記憶)

# ============================================================================
# GitHub MCP - GitHub連携 (Issue・PR・コード検索)
# https://github.com/settings/tokens → New personal access token (classic)
# 権限: repo, read:user, read:org (必要に応じて)
# ============================================================================
GITHUB_TOKEN=your_github_personal_access_token_here

# ============================================================================
# Discord Bot (公開URL不要・Bot Token 1つだけ)
# https://discord.com/developers/applications
# ============================================================================
# 1. New Application → Bot → Add Bot → Reset Token → コピー
# 2. Bot → Privileged Gateway Intents → MESSAGE CONTENT INTENT を ON
# 3. OAuth2 → URL Generator → scopes: bot → Send Messages で招待URL生成
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================================================
# Notion - 長期記憶
# https://www.notion.so/my-integrations
# ============================================================================
NOTION_API_KEY=your_notion_api_key_here

# ============================================================================
# llama.cpp (CT 101 - HP ProDesk 600)
# CT 100 から CT 101 に接続する場合は 192.168.11.232 を使用
# ============================================================================
LLAMACPP_ENDPOINT=http://192.168.11.232:8080
LLAMACPP_THREADS=6          # i5-8500 (6C/6T)
LLAMACPP_CONTEXT_SIZE=4096
LLAMACPP_BATCH_SIZE=512
LLAMACPP_MLOCK=true

# ============================================================================
# ログ・メモリ設定
# ============================================================================
LOG_LEVEL=INFO
MEMORY_FILE=bushidan_memory.jsonl
MEMORY_MAX_SIZE=10000

# ============================================================================
# APIキー取得先まとめ
# ============================================================================
#
# サービス           | URL                                 | 用途
# ------------------|-------------------------------------|-------------------------
# Claude            | console.anthropic.com               | 将軍 (必須)
# Gemini            | ai.google.dev                       | 最終防衛線 (必須)
# OpenRouter        | openrouter.ai                       | Qwen全シリーズ (推奨)
# Moonshot (Kimi)   | platform.moonshot.cn                | 傭兵 並列実行 (推奨)
# Groq              | console.groq.com                    | Simple タスク (無料)
# Tavily            | tavily.com                          | Web検索 (無料枠あり)
# Smithery          | smithery.ai                         | MCP実行基盤 (1キー)
# Exa               | exa.ai                              | セマンティック検索 (任意)
# Mem0              | mem0.ai                             | グラフ記憶 (任意)
# Discord           | discord.com/developers/applications | インターフェース (任意)
# Notion            | notion.so/my-integrations           | 長期記憶 (任意)
# GitHub            | github.com/settings/tokens          | GitHub MCP (任意)

# ============================================================================
# システムモード説明
# ============================================================================
#
# battalion - フルシステム (将軍+軍師+家老+大将+足軽+全MCP)
#             複雑な開発タスク向け
#
# company   - Slackモード (家老+大将+足軽+記憶MCP)
#             日常の開発作業向け
#
# platoon   - HA OSモード (大将+足軽+動的MCP)
#             音声クエリ・IoT連携向け
