# ============================================================================
# Bushidan Multi-Agent System v11.5 - Configuration Template
# 脱中国企業: Alibaba/Qwen/Kimi/Moonshot 全排除
# このファイルを .env にコピーして各APIキーを記入してください
# ============================================================================

# システムモード
SYSTEM_MODE=battalion  # battalion, company, platoon

# ============================================================================
# Anthropic - 大元帥 (Claude Opus 4.6) + 将軍 (Claude Sonnet 4.6)
# https://console.anthropic.com/
# ============================================================================
CLAUDE_API_KEY=your_claude_api_key_here

# ============================================================================
# OpenAI - 軍師 (o3-mini)
# https://platform.openai.com/api-keys
# ============================================================================
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# Mistral AI - 参謀-A (Mistral Large 3)
# https://console.mistral.ai/
# ============================================================================
# MISTRAL_API_KEY=your_mistral_api_key_here

# ============================================================================
# xAI - 参謀-B (Grok 4.1 Fast)
# https://console.x.ai/
# ============================================================================
# XAI_API_KEY=your_xai_api_key_here

# ============================================================================
# Google - 家老-A (Gemini 3 Flash) + 検校 (Gemini 3 Flash Vision)
# https://ai.google.dev/
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# Groq - 家老-B (Llama 3.3 70B, 無料)
# https://console.groq.com/
# ============================================================================
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# Tavily - Web検索MCP (1,000回/月無料)
# https://tavily.com/
# ============================================================================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================================
# Smithery MCP
# https://smithery.ai/
# ============================================================================
SMITHERY_API_KEY=your_smithery_api_key_here

# ============================================================================
# GitHub MCP
# https://github.com/settings/tokens
# ============================================================================
GITHUB_TOKEN=your_github_personal_access_token_here

# ============================================================================
# Discord Bot
# https://discord.com/developers/applications
# ============================================================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================================================
# Mattermost Bot (192.168.11.234:8065)
# team: bushidan / channel: bushidan-party
# Bot Token: Mattermost管理者 → Integrations → Bot Accounts
# ============================================================================
MATTERMOST_URL=192.168.11.234
MATTERMOST_PORT=8065
MATTERMOST_TOKEN=your_mattermost_bot_token_here
MATTERMOST_TEAM=bushidan

# ============================================================================
# Notion - 長期記憶
# https://www.notion.so/my-integrations
# ============================================================================
NOTION_API_KEY=your_notion_api_key_here

# ============================================================================
# 隠密 (Onmitsu) - Nemotron-3-Nano (ローカルLLM専用サーバー, EliteDesktとは独立)
# ============================================================================
LLAMACPP_ENDPOINT=http://192.168.11.239:8080
LLAMACPP_THREADS=6
LLAMACPP_CONTEXT_SIZE=8192
LLAMACPP_BATCH_SIZE=512
LLAMACPP_MLOCK=true

# 隠密 オンデマンド: ELYZA JP 8B
ELYZA_HOST=192.168.11.239
ELYZA_PORT=8081

# ============================================================================
# ログ・メモリ設定
# ============================================================================
LOG_LEVEL=INFO
MEMORY_FILE=bushidan_memory.jsonl
MEMORY_MAX_SIZE=10000
